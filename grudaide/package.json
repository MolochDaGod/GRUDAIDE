{
  "name": "grudaide",
  "version": "1.0.0",
  "description": "GRUDAIDE - GitHub App & AI Worker Management Platform for Grudge Studio",
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "github-app",
    "ai-workers",
    "deployment",
    "grudge-studio",
    "warp",
    "automation"
  ],
  "author": "Grudge Studio",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@octokit/auth-app": "^7.1.4",
    "@octokit/rest": "^21.0.2",
    "@octokit/webhooks": "^13.4.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "uuid": "^11.1.1",
    "winston": "^3.14.2",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
