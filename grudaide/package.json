{
  "name": "@grudge-studio/grudaide",
  "version": "1.0.0",
  "description": "AI Worker Deployment Platform for Grudge Studio – GitHub App, worker management, and deployment orchestration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npx tsc --noEmit",
    "compile": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "test": "npx jest --passWithNoTests",
    "test:watch": "npx jest --watch",
    "test:coverage": "npx jest --coverage",
    "lint": "npx eslint src tests --ext .ts",
    "typecheck": "npx tsc --noEmit",
    "typecheck:test": "npx tsc --project tsconfig.test.json"
  },
  "keywords": [
    "github-app",
    "ai-workers",
    "deployment",
    "orchestration",
    "grudge-studio"
  ],
  "author": "Grudge Studio",
  "license": "AGPL-3.0",
  "dependencies": {
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^21.1.0",
    "@octokit/webhooks": "^14.2.0",
    "@octokit/webhooks-types": "^7.6.1",
    "express": "^5.2.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.29",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
