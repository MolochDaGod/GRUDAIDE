# ─────────────────────────────────────────────────────────────────────────────
# GRUDAIDE - Environment Variable Template
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub App Credentials ───────────────────────────────────────────────────
# Required: GitHub App ID (from your App's settings page)
GITHUB_APP_ID=

# Required: RSA private key for the GitHub App (escape newlines as \n for single-line)
GITHUB_PRIVATE_KEY=

# Required: Webhook secret set in your GitHub App settings
GITHUB_WEBHOOK_SECRET=

# Optional: GitHub App OAuth client credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: Installation ID for a specific repository/org installation
GITHUB_INSTALLATION_ID=

# ── Repository (for storage layer) ──────────────────────────────────────────
GITHUB_OWNER=MolochDaGod
GITHUB_REPO=GRUDAIDE

# Optional: GitHub Projects V2 project ID
GITHUB_PROJECT_ID=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
WEBHOOK_PATH=/webhooks
HEALTH_PATH=/health

# ── Deployment ───────────────────────────────────────────────────────────────
NODE_ENV=development

# Optional: Private npm registry
NPM_REGISTRY=https://registry.npmjs.org
# Optional: npm auth token for private packages
NPM_TOKEN=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_DIR=./logs

# ── Storage Labels ───────────────────────────────────────────────────────────
STORAGE_ISSUE_LABEL=grudaide:data
STORAGE_STATE_LABEL=grudaide:state

# ── Workers ──────────────────────────────────────────────────────────────────
# Optional: JSON array of worker config overrides
# GRUDAIDE_WORKERS=[{"id":"my-worker","name":"My Worker","type":"custom","triggers":["push"]}]

# Optional: Path to GRUDAIDE config file (default: ./grudaide.config.yml)
# GRUDAIDE_CONFIG=./grudaide.config.yml
